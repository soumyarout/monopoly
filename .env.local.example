# ── Required for Vercel deployment (Upstash Redis) ─────────────────────────────
# Create a free Redis DB at https://console.upstash.com/
# Copy the REST URL and token from the "REST API" tab
# Leave these blank for local dev — an in-memory store is used instead
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
